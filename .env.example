# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/quiz-management-system

# Optional DNS override for mongodb+srv connections on machines with broken local DNS forwarding
DNS_SERVERS=

# Session Secret
SESSION_SECRET=change_this_to_a_long_random_secret

# App
PORT=3000
NODE_ENV=development

# Code Execution, optional
PISTON_API_URL=http://localhost:2000/api/v2/execute
PISTON_HTTP_TIMEOUT_MS=60000
