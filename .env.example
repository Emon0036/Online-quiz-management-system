# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/quiz-management-system

# Session Secret
SESSION_SECRET=your_session_secret_key_here_change_in_production

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Server Port
PORT=3000
NODE_ENV=development

# Code Execution (Piston - self-hosted)
# Self-hosted endpoint: http://localhost:2000/api/v2/execute
# Public endpoint (whitelist-only as of 2/15/2026): https://emkc.org/api/v2/piston/execute
PISTON_API_URL=http://localhost:2000/api/v2/execute

# First-time executions can be slow while Piston downloads runtimes.
PISTON_HTTP_TIMEOUT_MS=60000

# Password reset URLs are printed in the server console in development.
# Add an email provider before using reset emails in production.
