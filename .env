# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/quiz-management-system

# Session Secret
SESSION_SECRET=mysecret123

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Server Port
PORT=3000
NODE_ENV=development

# Password reset URLs are printed in the server console in development.
# Add an email provider before using reset emails in production.
