<% layout('layouts/main') %>
<section class="auth-wrap">
  <div class="auth-card">
    <h1>Welcome back</h1>
    <p class="text-muted">Log in to continue to your dashboard.</p>
    <form action="/auth/login" method="POST" class="vstack gap-3">
      <input class="form-control" type="email" name="email" placeholder="Email address" required>
      <input class="form-control" type="password" name="password" placeholder="Password" required>
      <button class="btn btn-primary w-100" type="submit">Login</button>
    </form>
    <a class="btn btn-outline-danger w-100 mt-3" href="/auth/google"><i class="fa-brands fa-google me-2"></i>Continue with Google</a>
    <div class="d-flex justify-content-between small mt-3">
      <a href="/auth/register">Create account</a>
      <a href="/auth/forgot-password">Forgot password?</a>
    </div>
  </div>
</section>
