<% layout('layouts/main') %>
<section class="container py-4">
  <!-- Result Summary Section -->
  <div class="result-hero">
    <span class="eyebrow">Result</span>
    <h1><%= attempt.quiz.title %></h1>
    <!-- Display overall percentage score in a visual circle -->
    <div class="score-circle"><%= attempt.percentage %>%</div>
    <!-- Show pass/fail/pending status -->
    <p class="lead"><%= attempt.status === 'pending-review' ? 'Pending manual review' : attempt.passed ? 'Passed' : 'Needs improvement' %></p>
    <!-- Show marks breakdown: obtained vs total -->
    <p><%= attempt.score %> out of <%= attempt.totalMarks %> marks</p>
  </div>

  <!-- Detailed Answer Review Section -->
  <div class="form-panel mt-4">
    <h2 class="mb-3">Answer Review</h2>
    
    <% attempt.answers.forEach((answer, index) => { %>
      <div class="review-item mb-4 p-4 rounded-3 shadow-sm">
        <div class="d-flex align-items-start justify-content-between mb-3 gap-3">
          <div>
            <h3 class="h6 mb-1"><span class="badge bg-primary me-2"><%= index + 1 %></span><%= answer.question.questionText %></h3>
            <p class="text-muted mb-0">Max marks: <strong><%= answer.question.marks %></strong></p>
          </div>
          <div class="text-end">
            <span class="badge <%= answer.needsManualReview ? 'text-bg-warning' : answer.isCorrect ? 'text-bg-success' : 'text-bg-danger' %>">
              <%= answer.needsManualReview ? 'Pending Review' : `${answer.marksObtained}/${answer.question.marks} marks` %>
            </span>
          </div>
        </div>

        <% if (answer.question.type === 'coding') { %>
          <div class="mb-3">
            <p class="mb-1 text-muted"><strong>Your code:</strong></p>
            <pre class="code-block bg-slate-950 text-slate-100 p-4 rounded-lg overflow-x-auto"><code><%= answer.answer || '(No code submitted)' %></code></pre>
          </div>
        <% } else { %>
          <div class="mb-3">
            <p class="mb-1 text-muted"><strong>Your answer:</strong></p>
            <div class="p-3 bg-gray-50 rounded"><span class="fw-semibold <%= answer.isCorrect ? 'text-success' : answer.needsManualReview ? 'text-warning' : 'text-danger' %>"><%= answer.answer || '(Not answered)' %></span></div>
          </div>
        <% } %>

        <% if (!answer.needsManualReview && !answer.isCorrect && answer.question.type !== 'coding') { %>
          <div class="alert alert-info mb-3">
            <strong>Correct answer:</strong> <%= answer.question.correctAnswer %>
          </div>
        <% } %>

        <% if (answer.question.explanation && answer.question.explanation.trim()) { %>
          <div class="alert alert-light border border-secondary mb-3">
            <strong>Explanation:</strong>
            <p class="mb-0 mt-2"><%= answer.question.explanation %></p>
          </div>
        <% } %>

        <% if (answer.reviewComment && answer.reviewComment.trim()) { %>
          <div class="alert alert-secondary mb-0">
            <strong>Teacher feedback:</strong>
            <p class="mb-0 mt-2"><%= answer.reviewComment %></p>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>

  <!-- Action Buttons -->
  <div class="mt-4 mb-4">
    <a href="/enrollments/browse" class="btn btn-primary">Browse More Exams</a>
    <a href="/student/history" class="btn btn-outline-secondary">View History</a>
  </div>
</section>
