<% layout('layouts/main') %>
<section class="container py-4">
  <div class="quiz-header">
    <div><span class="eyebrow"><%= quiz.category %></span><h1><%= quiz.title %></h1></div>
    <div class="timer" data-duration="<%= quiz.duration %>"><i class="fa-regular fa-clock me-2"></i><span id="timerText"><%= quiz.duration %>:00</span></div>
  </div>
  <div class="alert alert-warning py-2 small">
    <i class="fa-solid fa-shield-halved me-2"></i>
    Leaving this tab/window or switching focus will auto-submit your exam immediately.
  </div>
  <form id="quizForm" action="/student/quizzes/<%= quiz._id %>/submit" method="POST" class="form-panel">
    <input type="hidden" name="timeSpent" id="timeSpent" value="0">
    <input type="hidden" name="autoSubmitted" id="autoSubmitted" value="0">
    <input type="hidden" name="autoSubmitReason" id="autoSubmitReason" value="">
    
    <% quiz.questions.forEach((question, index) => { %>
      <div class="question-block">
        <h2 class="h5"><%= index + 1 %>. <%= question.questionText %> <span class="text-muted small">(<%= question.marks %> marks)</span></h2>
        
        <% if (question.type === 'coding') { %>
          <!-- Coding Question Section -->
          <div class="coding-question mb-3">
            <% if (question.codeTemplate && question.codeTemplate.trim()) { %>
              <div class="alert alert-info small">
                <strong>Template:</strong><br>
                <pre style="background: #f5f5f5; padding: 10px; border-radius: 4px; font-size: 12px;"><%= question.codeTemplate %></pre>
              </div>
            <% } %>
            
            <% if (question.testCases && question.testCases.length > 0) { %>
              <div class="alert alert-info small">
                <strong>Test Cases:</strong>
                <% question.testCases.forEach((testCase, tcIndex) => { %>
                  <div class="mt-2">
                    <strong>Test <%= tcIndex + 1 %>:</strong><br>
                    <strong>Input:</strong> <code><%= testCase.input %></code><br>
                    <strong>Expected Output:</strong> <code><%= testCase.expectedOutput %></code>
                  </div>
                <% }) %>
              </div>
            <% } %>
            
            <label class="form-label">Language: <strong><%= question.language || 'Coding' %></strong></label>
            <textarea 
              class="form-control code-editor" 
              name="code[<%= question._id %>]" 
              data-language="<%= question.language || '' %>"
              rows="10" 
              placeholder="Write your code here..."
              required><%= question.codeTemplate || '' %></textarea>
          </div>
        <% } else if (question.type === 'short-answer') { %>
          <!-- Short Answer Question Section -->
          <textarea class="form-control" name="answers[<%= question._id %>]" rows="3" placeholder="Write your answer" required></textarea>
        <% } else { %>
          <!-- Multiple Choice / True-False Question Section -->
          <% question.options.forEach((option) => { %>
            <label class="answer-option">
              <input type="radio" name="answers[<%= question._id %>]" value="<%= option %>" required>
              <span><%= option %></span>
            </label>
          <% }) %>
        <% } %>
      </div>
    <% }) %>
    
    <button class="btn btn-primary btn-lg" type="submit">Submit <%= quiz.examType === 'coding-test' ? 'Exam' : 'Quiz' %></button>
  </form>
</section>

<style>
  .code-editor {
    font-family: 'Courier New', monospace;
    font-size: 14px;
    line-height: 1.5;
    background-color: #f8f8f8;
    border: 1px solid #ddd;
  }
  
  .coding-question {
    background: #f9f9f9;
    padding: 15px;
    border-radius: 6px;
    border-left: 4px solid #007bff;
  }
  
  .coding-question pre {
    margin: 0;
  }
  
  .answer-option {
    display: block;
    padding: 10px;
    margin: 5px 0;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s;
  }
  
  .answer-option:hover {
    background: #f5f5f5;
  }
  
  .answer-option input[type="radio"]:checked + span {
    color: #007bff;
    font-weight: bold;
  }
  
  .timer {
    display: inline-block;
    padding: 10px 20px;
    background: #007bff;
    color: white;
    border-radius: 4px;
    font-weight: bold;
  }
  
  .timer-danger {
    background: #dc3545;
  }
</style>

<script src="/js/quizTimer.js"></script>
