<% layout('layouts/main') %>
<section class="container py-4">
  <div class="page-heading d-flex justify-content-between align-items-center mb-4">
    <div>
      <span class="eyebrow">Student</span>
      <h1>Review Center</h1>
      <p class="text-muted">Track exam submissions that are pending teacher review or have completed review.</p>
    </div>
    <a href="/student/history" class="btn btn-outline-primary">View Full History</a>
  </div>

  <% if (!reviewAttempts.length) { %>
    <div class="empty-state">No review submissions found yet. Take a quiz to start a review request.</div>
  <% } else { %>
    <div class="table-card">
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>Exam</th>
              <th>Status</th>
              <th>Score / Status</th>
              <th>Submitted</th>
              <th class="text-end">Action</th>
            </tr>
          </thead>
          <tbody>
            <% reviewAttempts.forEach((attempt) => { %>
              <tr>
                <td>
                  <strong><%= attempt.quiz?.title || 'Unknown Exam' %></strong>
                  <div class="small text-muted"><%= attempt.quiz?.category || 'General' %></div>
                </td>
                <td>
                  <% if (attempt.status === 'pending-review') { %>
                    <span class="badge text-bg-warning">Pending Review</span>
                  <% } else { %>
                    <span class="badge text-bg-success">Reviewed</span>
                  <% } %>
                </td>
                <td>
                  <% if (attempt.status === 'pending-review') { %>
                    <span class="text-muted">Awaiting feedback</span>
                  <% } else { %>
                    <span><%= attempt.percentage %> %</span>
                  <% } %>
                </td>
                <td><%= new Date(attempt.submittedAt).toLocaleDateString() %></td>
                <td class="text-end">
                  <a href="/student/results/<%= attempt._id %>" class="btn btn-sm btn-outline-primary">View Review</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</section>
