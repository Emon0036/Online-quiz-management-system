<% layout('layouts/main') %>
<%
  const dashboardExamTypeCounts = {
    quiz: 0,
    'true-false': 0,
    'short-answer': 0,
    'coding-test': 0,
    ...(examTypeCounts || {})
  };
  const dashboardStats = {
    enrolledCount: 0,
    completedCount: 0,
    pendingReviewCount: 0,
    availableQuizCount: 0,
    ...(stats || {})
  };
  const dashboardProgress = {
    averageScore: 0,
    totalPoints: 0,
    streak: 0,
    totalQuizzes: 0,
    completedQuizzes: 0,
    inProgressQuizzes: 0,
    totalAttempts: 0,
    passedQuizzes: 0,
    failedQuizzes: 0,
    ...(progress || {})
  };
  const latestAttempt = recentAttempts && recentAttempts.length ? recentAttempts[0] : null;
  const latestAttemptScore = latestAttempt ? Number(latestAttempt.score || 0) : 0;
  const latestAttemptTotal = latestAttempt ? Number(latestAttempt.totalMarks || 0) : 0;
  const latestAttemptPercent = latestAttempt ? Number(latestAttempt.percentage || 0) : 0;
  const progressTotalQuizzes = Number(dashboardProgress.totalQuizzes || dashboardStats.enrolledCount || 0);
  const progressCompletedQuizzes = Number(dashboardProgress.completedQuizzes || 0);
  const progressInProgressQuizzes = Number(dashboardProgress.inProgressQuizzes || 0);
  const progressTotalAttempts = Number(dashboardProgress.totalAttempts || 0);
  const progressPassedQuizzes = Number(dashboardProgress.passedQuizzes || 0);
  const progressFailedQuizzes = Number(dashboardProgress.failedQuizzes || 0);
  const progressReviewedOutcomes = progressPassedQuizzes + progressFailedQuizzes;
  const dashboardCompletionRate = progressTotalQuizzes
    ? Math.max(0, Math.min(100, Math.round((progressCompletedQuizzes / progressTotalQuizzes) * 100)))
    : 0;
  const dashboardPassRate = progressReviewedOutcomes
    ? Math.max(0, Math.min(100, Math.round((progressPassedQuizzes / progressReviewedOutcomes) * 100)))
    : 0;
  const studentExamSegments = [
    {
      label: 'Quizzes',
      detail: 'Multiple choice and mixed exams',
      count: Number(dashboardExamTypeCounts.quiz || 0),
      color: '#0e5c8b'
    },
    {
      label: 'True/False',
      detail: 'Fast concept checks',
      count: Number(dashboardExamTypeCounts['true-false'] || 0),
      color: '#1c9b8f'
    },
    {
      label: 'Short Answer',
      detail: 'Teacher-reviewed responses',
      count: Number(dashboardExamTypeCounts['short-answer'] || 0),
      color: '#f59e0b'
    },
    {
      label: 'Coding Tests',
      detail: 'Hands-on programming exams',
      count: Number(dashboardExamTypeCounts['coding-test'] || 0),
      color: '#c2410c'
    }
  ];
  const totalExamMix = studentExamSegments.reduce((sum, segment) => sum + segment.count, 0);
  let studentChartFill = 'conic-gradient(rgba(67, 108, 140, 0.18) 0deg 360deg)';

  if (totalExamMix > 0) {
    let currentAngle = 0;
    studentChartFill = `conic-gradient(${studentExamSegments
      .filter((segment) => segment.count > 0)
      .map((segment) => {
        const startAngle = currentAngle;
        currentAngle += (segment.count / totalExamMix) * 360;
        return `${segment.color} ${startAngle}deg ${currentAngle}deg`;
      })
      .join(', ')})`;
  }
%>

<section class="page-shell">
  <div class="page-container page-stack">
    <section class="dashboard-hero animate-fade-in">
      <div class="dashboard-hero__grid">
        <div class="dashboard-hero__content">
          <span class="eyebrow">Student Workspace</span>
          <h1>Welcome back, <%= currentUser.name %>.</h1>
          <p>See your exam mix, review status, and progress from one clear dashboard.</p>
          <div class="hero-action-row mt-4">
            <a href="/enrollments/browse" class="btn btn-primary">
              <i class="fas fa-search"></i>
              Browse exams
            </a>
            <a href="/enrollments/my-quizzes" class="btn btn-outline-primary">
              <i class="fas fa-book-open"></i>
              Continue my exams
            </a>
            <a href="/enrollments/progress" class="btn btn-outline-primary">
              <i class="fas fa-chart-line"></i>
              View progress
            </a>
          </div>
        </div>

        <div class="dashboard-hero__aside hero-mini-grid">
          <div class="hero-mini-card">
            <span>Enrolled</span>
            <strong><%= dashboardStats.enrolledCount %></strong>
            <small>exams currently in your workspace</small>
          </div>
          <div class="hero-mini-card">
            <span>Completed</span>
            <strong><%= dashboardStats.completedCount %></strong>
            <small>submitted attempts on record</small>
          </div>
          <div class="hero-mini-card">
            <span>Pending review</span>
            <strong><%= dashboardStats.pendingReviewCount %></strong>
            <small>teacher feedback still waiting</small>
          </div>
          <div class="hero-mini-card">
            <span>Available</span>
            <strong><%= dashboardStats.availableQuizCount %></strong>
            <small>new exams you can still join</small>
          </div>
        </div>
      </div>
    </section>

    <section class="dashboard-overview">
      <article class="chart-card">
        <div class="panel-header">
          <div class="panel-header__copy">
            <span class="eyebrow">Exam Overview</span>
            <h2>Your enrolled exam mix</h2>
            <p>A simple breakdown of the exam types in your current workspace.</p>
          </div>
        </div>

        <div class="chart-card__body">
          <div class="donut-chart" style="--chart-fill: <%= studentChartFill %>;">
            <div class="donut-chart__center">
              <strong class="donut-chart__value"><%= totalExamMix %></strong>
              <span class="donut-chart__label">Tracked exams</span>
            </div>
          </div>

          <div class="chart-legend">
            <% studentExamSegments.forEach((segment) => { %>
              <div class="legend-item">
                <span class="legend-dot" style="background: <%= segment.color %>;"></span>
                <div class="legend-copy">
                  <strong><%= segment.label %></strong>
                  <span><%= segment.detail %></span>
                </div>
                <span class="legend-value"><%= segment.count %></span>
              </div>
            <% }) %>
          </div>
        </div>
      </article>

      <div class="dashboard-side-stack">
        <div class="compact-stat-grid">
          <article class="compact-stat">
            <span>Average Score</span>
            <strong><%= dashboardProgress.averageScore %>%</strong>
            <small>Across recorded attempts</small>
          </article>
          <article class="compact-stat">
            <span>Total Points</span>
            <strong><%= dashboardProgress.totalPoints %></strong>
            <small>Points earned so far</small>
          </article>
          <article class="compact-stat">
            <span>Current Streak</span>
            <strong><%= dashboardProgress.streak %></strong>
            <small>Days of activity in a row</small>
          </article>
        </div>

        <div class="support-card">
          <span class="eyebrow">Next Step</span>
          <h3>Keep today focused</h3>
          <p>
            <% if (dashboardStats.pendingReviewCount > 0) { %>
              You have <strong><%= dashboardStats.pendingReviewCount %></strong> submission<%= dashboardStats.pendingReviewCount === 1 ? '' : 's' %> waiting for teacher feedback.
            <% } else if (dashboardStats.availableQuizCount > 0) { %>
              There are <strong><%= dashboardStats.availableQuizCount %></strong> more exam<%= dashboardStats.availableQuizCount === 1 ? '' : 's' %> available if you want to join something new.
            <% } else { %>
              Your dashboard is clear, so this is a good time to improve your next score.
            <% } %>
          </p>
          <div class="support-list">
            <a href="/enrollments/browse"><i class="fas fa-search"></i><span>Browse and enroll</span></a>
            <a href="/enrollments/my-quizzes"><i class="fas fa-book-open"></i><span>Open my exams</span></a>
            <a href="/student/reviews"><i class="fas fa-comments"></i><span>Check review center</span></a>
            <a href="/student/history"><i class="fas fa-clock-rotate-left"></i><span>View attempt history</span></a>
          </div>
        </div>
      </div>
    </section>

    <section class="score-explainer">
      <div class="panel-header">
        <div class="panel-header__copy">
          <span class="eyebrow">Score Breakdown</span>
          <h2>How your marks, points, and progress are calculated</h2>
          <p>This is the exact flow the system follows after you submit an exam, including what waits for teacher review.</p>
        </div>
        <a href="/student/history" class="btn btn-outline-primary btn-sm">Open score history</a>
      </div>

      <div class="calculation-snapshot">
        <article>
          <span>Latest attempt formula</span>
          <strong>
            <% if (latestAttempt) { %>
              <%= latestAttemptScore %>/<%= latestAttemptTotal %> = <%= latestAttemptPercent %>%
            <% } else { %>
              No attempt yet
            <% } %>
          </strong>
          <small>Percentage is rounded from marks earned divided by total marks.</small>
        </article>
        <article>
          <span>Finalized attempts</span>
          <strong><%= progressTotalAttempts %></strong>
          <small>Used for average score, points, streak, and global leaderboard.</small>
        </article>
        <article>
          <span>Pending review</span>
          <strong><%= dashboardStats.pendingReviewCount %></strong>
          <small>Manual answers are not added to progress until a teacher finishes marking.</small>
        </article>
        <article>
          <span>Completion progress</span>
          <strong><%= dashboardCompletionRate %>%</strong>
          <small><%= progressCompletedQuizzes %> completed out of <%= progressTotalQuizzes %> enrolled progress records.</small>
        </article>
      </div>

      <div class="calculation-flow">
        <article class="calculation-step">
          <span class="calculation-step__number">1</span>
          <div>
            <h3>Question marks are added first</h3>
            <p>Multiple-choice and true/false questions are auto-graded. A correct answer gets the full question marks, and an incorrect or blank answer gets 0 for that question.</p>
          </div>
        </article>
        <article class="calculation-step">
          <span class="calculation-step__number">2</span>
          <div>
            <h3>Manual questions wait for the teacher</h3>
            <p>Short-answer and coding questions start with 0 temporary marks and a pending-review status. Your final score updates only after the teacher enters marks and feedback.</p>
          </div>
        </article>
        <article class="calculation-step">
          <span class="calculation-step__number">3</span>
          <div>
            <h3>Percentage decides pass or fail</h3>
            <p>The system calculates <strong>percentage = round((marks earned / total marks) x 100)</strong>. You pass when that percentage is equal to or higher than the exam pass mark.</p>
          </div>
        </article>
        <article class="calculation-step">
          <span class="calculation-step__number">4</span>
          <div>
            <h3>Progress updates after final scoring</h3>
            <p>Auto-graded exams update immediately. Teacher-reviewed exams update later, after review. Then your attempts, average score, total points, completion, streak, and leaderboard numbers are refreshed.</p>
          </div>
        </article>
      </div>

      <div class="formula-grid">
        <article class="formula-card">
          <i class="fas fa-percent"></i>
          <h3>Average score</h3>
          <p>Your average is a rolling average of finalized percentages: old average plus the new finalized percentage, divided across all finalized attempts.</p>
          <strong>Current: <%= dashboardProgress.averageScore %>%</strong>
        </article>
        <article class="formula-card">
          <i class="fas fa-star"></i>
          <h3>Total points</h3>
          <p>Points use your percentage with a difficulty multiplier: Easy x1, Medium x1.25, Hard x1.5. The result is rounded and added to your total.</p>
          <strong>Current: <%= dashboardProgress.totalPoints %></strong>
        </article>
        <article class="formula-card">
          <i class="fas fa-fire"></i>
          <h3>Streak</h3>
          <p>Your streak increases when you finalize activity on the next day. Same-day activity keeps the streak, and a missed day starts it again from 1.</p>
          <strong>Current: <%= dashboardProgress.streak %> day<%= Number(dashboardProgress.streak || 0) === 1 ? '' : 's' %></strong>
        </article>
        <article class="formula-card">
          <i class="fas fa-trophy"></i>
          <h3>Leaderboards</h3>
          <p>Quiz leaderboards keep your best percentage for that exam. The global leaderboard ranks students by total points first, then average score for ties.</p>
          <strong>Pass rate: <%= dashboardPassRate %>%</strong>
        </article>
        <article class="formula-card">
          <i class="fas fa-hourglass-half"></i>
          <h3>In progress</h3>
          <p>Enrolling adds an exam to your progress list. It remains in progress until a submitted attempt is finalized by auto-grading or teacher review.</p>
          <strong>Current: <%= progressInProgressQuizzes %></strong>
        </article>
        <article class="formula-card">
          <i class="fas fa-medal"></i>
          <h3>Grades</h3>
          <p>Result grades follow the final percentage: A is 90%+, B is 80%+, C is 70%+, D is 60%+, and F is below 60%.</p>
          <strong>Passed: <%= progressPassedQuizzes %> / Failed: <%= progressFailedQuizzes %></strong>
        </article>
      </div>
    </section>

    <section class="table-card table-shell">
      <div class="panel-header">
        <div class="panel-header__copy">
          <span class="eyebrow">Quick Access</span>
          <h2>Open the exam type you need</h2>
          <p>Each card takes you directly to that filtered exam list.</p>
        </div>
      </div>

      <div class="action-grid">
        <a href="/enrollments/my-quizzes?type=quiz" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill approved">Quiz</span>
              <h3 class="mt-3">Multiple Choice</h3>
              <p>Quick practice with standard quiz questions.</p>
            </div>
            <span class="action-card__count"><%= dashboardExamTypeCounts.quiz %></span>
          </div>
          <span class="action-card__footer">Open quizzes <i class="fas fa-arrow-right"></i></span>
        </a>

        <a href="/enrollments/my-quizzes?type=true-false" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill approved">True/False</span>
              <h3 class="mt-3">Concept Checks</h3>
              <p>Fast assessments for quick review sessions.</p>
            </div>
            <span class="action-card__count"><%= dashboardExamTypeCounts['true-false'] %></span>
          </div>
          <span class="action-card__footer">View assessments <i class="fas fa-arrow-right"></i></span>
        </a>

        <a href="/enrollments/my-quizzes?type=short-answer" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill pending">Short Answer</span>
              <h3 class="mt-3">Teacher Review</h3>
              <p>Written responses that include manual feedback.</p>
            </div>
            <span class="action-card__count"><%= dashboardExamTypeCounts['short-answer'] %></span>
          </div>
          <span class="action-card__footer">Go to reviewed work <i class="fas fa-arrow-right"></i></span>
        </a>

        <a href="/enrollments/my-quizzes?type=coding-test" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill approved">Coding</span>
              <h3 class="mt-3">Coding Tests</h3>
              <p>Programming exams that test practical skills.</p>
            </div>
            <span class="action-card__count"><%= dashboardExamTypeCounts['coding-test'] %></span>
          </div>
          <span class="action-card__footer">Open coding tests <i class="fas fa-arrow-right"></i></span>
        </a>
      </div>
    </section>

    <section class="table-card table-shell">
      <div class="panel-header">
        <div class="panel-header__copy">
          <span class="eyebrow">Recent Activity</span>
          <h2>Latest attempts</h2>
          <p>Your most recent quiz submissions and scores.</p>
        </div>
        <a href="/student/history" class="btn btn-outline-primary btn-sm">View full history</a>
      </div>

      <% if (recentAttempts && recentAttempts.length > 0) { %>
        <div class="activity-list">
          <% recentAttempts.slice(0, 5).forEach((attempt) => { %>
            <% const attemptQuiz = attempt.quiz || {}; %>
            <% const attemptDate = attempt.submittedAt || attempt.createdAt; %>
            <article class="activity-item">
              <div class="activity-item__main">
                <span class="activity-item__icon"><i class="fas fa-file-signature"></i></span>
                <div>
                  <p class="activity-item__title"><%= attemptQuiz.title || 'Removed quiz' %></p>
                  <p class="activity-item__meta">
                    <%= attemptQuiz.category || 'General' %> ·
                    <%= attemptDate ? new Date(attemptDate).toLocaleDateString() : 'No date available' %>
                  </p>
                </div>
              </div>
              <div class="activity-score">
                <strong><%= attempt.percentage %>%</strong>
                <span><%= attempt.status === 'pending-review' ? 'Pending review' : 'Recorded score' %></span>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h3>No recent attempts yet</h3>
          <p>Start with an available exam and your latest activity will appear here.</p>
          <a href="/enrollments/browse" class="btn btn-primary mt-3">Browse exams</a>
        </div>
      <% } %>
    </section>
  </div>
</section>
