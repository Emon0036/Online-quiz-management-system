          <i class="fas fa-graduation-cap text-accent-600 text-2xl"></i>
        </div>
        <div class="absolute -bottom-4 -left-4 w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center animate-bounce-subtle" style="animation-delay: 1s">
          <i class="fas fa-star text-brand-600 text-xl"></i>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
