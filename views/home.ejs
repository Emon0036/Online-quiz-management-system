<% layout('layouts/main') %>

<%- include('partials/header', { eyebrow: 'Online Quiz Management System', heading: 'Modern Quiz Platform', subheading: 'Responsive, animated, and production-style interface for students and teachers.' }) %>

<section class="container dashboard-layout mt-4">
  <aside class="sidebar glass" data-sidebar>
    <h2 class="h6">Workspace</h2>
    <a href="/student/dashboard">Student Dashboard</a>
    <a href="/teacher/dashboard">Teacher Dashboard</a>
    <a href="/student/quizzes">Browse Quizzes</a>
    <a href="/teacher/quizzes/new">Create Quiz</a>
    <button class="btn btn-sm btn-primary mt-2" data-modal-open="demoModal">Open Modal</button>
    <button class="btn btn-sm btn-outline-primary mt-2" data-toast="Saved! UI action complete.">Toast Demo</button>
  </aside>

  <div>
    <div class="stat-grid reveal mb-4">
      <article class="stat-tile"><span>Published Quizzes</span><strong data-counter="128">0</strong></article>
      <article class="stat-tile"><span>Students</span><strong data-counter="942">0</strong></article>
      <article class="stat-tile"><span>Avg Completion</span><strong data-counter="84">0</strong></article>
    </div>

    <div class="progress-modern reveal mb-4"><span style="width:72%"></span></div>

    <div class="row g-4 mb-4">
      <div class="col-md-4"><div class="feature-card reveal"><i class="fa-solid fa-wand-magic-sparkles"></i><h3>Micro-interactions</h3><p>Smooth transitions, card hovers, and animated counters.</p></div></div>
      <div class="col-md-4"><div class="feature-card reveal"><i class="fa-solid fa-table"></i><h3>Advanced Tables</h3><p>Hover rows, sorting indicators, and glass styling.</p></div></div>
      <div class="col-md-4"><div class="feature-card reveal"><i class="fa-solid fa-mobile-screen-button"></i><h3>Mobile First</h3><p>Touch-friendly controls with responsive grids.</p></div></div>
    </div>

    <div class="table-card reveal mb-4">
      <h2 class="h5 mb-3">Recent Performance</h2>
      <table class="table-modern">
        <thead><tr><th class="sort-indicator">Quiz</th><th class="sort-indicator">Attempts</th><th>Score</th></tr></thead>
        <tbody><tr><td>JavaScript Basics</td><td>132</td><td>88%</td></tr><tr><td>Node Fundamentals</td><td>97</td><td>84%</td></tr></tbody>
      </table>
    </div>

    <div class="row g-3">
      <% featuredQuizzes.forEach((quiz) => { %>
        <div class="col-md-6 col-xl-4"><%- include('partials/card', { badge: quiz.category, title: quiz.title, description: quiz.description || 'A focused quiz for practice and assessment.', footer: `<div class='small text-muted'><i class='fa-regular fa-clock me-1'></i>${quiz.duration} min</div>` }) %></div>
      <% }) %>
    </div>
  </div>
</section>
