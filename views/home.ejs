<% layout('layouts/main') %>

<!-- Hero Section -->
<section class="hero-gradient relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-600/10 via-transparent to-accent-600/10"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="animate-fade-in">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-brand-100 text-brand-800 text-sm font-medium mb-6">
          <i class="fas fa-star text-yellow-500 mr-2"></i>
          Trusted by 10,000+ students and teachers
        </div>
        <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
          Transform Learning with
          <span class="text-gradient">Smart Quizzes</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8 leading-relaxed">
          Create, deliver, and analyze quizzes with advanced analytics. Empower teachers to build engaging assessments and help students track their progress with real-time insights.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/auth/register" class="btn-primary text-center px-8 py-4 text-lg">
            <i class="fas fa-rocket mr-2"></i>
            Get Started Free
          </a>
          <a href="/student/quizzes" class="btn-secondary text-center px-8 py-4 text-lg">
            <i class="fas fa-play mr-2"></i>
            Browse Quizzes
          </a>
        </div>
        <div class="flex items-center gap-8 mt-8 text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <i class="fas fa-check text-green-500"></i>
            <span>No credit card required</span>
          </div>
          <div class="flex items-center gap-2">
            <i class="fas fa-check text-green-500"></i>
            <span>Free forever plan</span>
          </div>
        </div>
      </div>

      <div class="relative animate-slide-up">
        <div class="glass-card p-8">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-brain text-brand-600 text-xl"></i>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Advanced Quiz</h3>
                <p class="text-sm text-gray-500">Mathematics - 45 mins</p>
              </div>
            </div>
            <span class="px-3 py-1 bg-green-100 text-green-800 text-xs font-medium rounded-full">Published</span>
          </div>

          <div class="space-y-4 mb-6">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Progress</span>
              <span class="text-sm font-medium text-gray-900">72%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-brand-600 h-2 rounded-full" style="width: 72%"></div>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-4 text-center">
            <div class="p-3 bg-gray-50 rounded-lg">
              <i class="fas fa-clock text-accent-600 mb-1"></i>
              <p class="text-xs text-gray-600">Timed</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
              <i class="fas fa-chart-line text-brand-600 mb-1"></i>
              <p class="text-xs text-gray-600">Analytics</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
              <i class="fas fa-trophy text-yellow-600 mb-1"></i>
              <p class="text-xs text-gray-600">Leaderboard</p>
