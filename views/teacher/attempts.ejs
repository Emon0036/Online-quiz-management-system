<% layout('layouts/main') %>
<section class="container py-4">
  <div class="page-heading"><div><span class="eyebrow">Attempts</span><h1><%= quiz.title %></h1></div><a class="btn btn-outline-secondary" href="/teacher/quizzes">Back</a></div>
  <div class="table-card">
    <table class="table align-middle">
      <thead><tr><th>Student</th><th>Score</th><th>Status</th><th>Submitted</th><th class="text-end">Action</th></tr></thead>
      <tbody>
        <% if (attempts.length === 0) { %><tr><td colspan="5" class="text-center text-muted py-4">No attempts yet.</td></tr><% } %>
        <% attempts.forEach((attempt) => { %>
          <tr>
            <td><%= attempt.student.name %><div class="small text-muted"><%= attempt.student.email %></div></td>
            <td><%= attempt.score %>/<%= attempt.totalMarks %> (<%= attempt.percentage %>%)</td>
            <td><span class="badge text-bg-<%= attempt.status === 'pending-review' ? 'warning' : 'success' %>"><%= attempt.status %></span></td>
            <td><%= attempt.submittedAt.toLocaleString() %></td>
            <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="/teacher/attempts/<%= attempt._id %>/review">Review</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
