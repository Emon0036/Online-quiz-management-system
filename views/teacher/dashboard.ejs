<% layout('layouts/main') %>
<%
  const teacherQuizSegments = [
    {
      label: 'Published',
      detail: 'Visible to students now',
      count: Number(stats.publishedQuizzes || 0),
      color: '#0e5c8b'
    },
    {
      label: 'Drafts',
      detail: 'Still being prepared',
      count: Number(stats.draftQuizzes || 0),
      color: '#1c9b8f'
    }
  ];
  const totalQuizMix = teacherQuizSegments.reduce((sum, segment) => sum + segment.count, 0);
  let teacherChartFill = 'conic-gradient(rgba(67, 108, 140, 0.18) 0deg 360deg)';

  if (totalQuizMix > 0) {
    let currentAngle = 0;
    teacherChartFill = `conic-gradient(${teacherQuizSegments
      .filter((segment) => segment.count > 0)
      .map((segment) => {
        const startAngle = currentAngle;
        currentAngle += (segment.count / totalQuizMix) * 360;
        return `${segment.color} ${startAngle}deg ${currentAngle}deg`;
      })
      .join(', ')})`;
  }
%>

<section class="page-shell">
  <div class="page-container page-stack">
    <section class="dashboard-hero animate-fade-in">
      <div class="dashboard-hero__grid">
        <div class="dashboard-hero__content">
          <span class="eyebrow">Teacher Workspace</span>
          <h1>Welcome back, <%= currentUser.name %>.</h1>
          <p>Create quizzes, publish them, and manage reviews from one clean teaching dashboard.</p>
          <div class="hero-action-row mt-4">
            <a href="/teacher/quizzes/new" class="btn btn-primary">
              <i class="fas fa-plus"></i>
              Create a new quiz
            </a>
            <a href="/teacher/reviews" class="btn btn-outline-primary">
              <i class="fas fa-clipboard-check"></i>
              Review submissions
            </a>
          </div>
        </div>

        <div class="dashboard-hero__aside hero-mini-grid">
          <div class="hero-mini-card">
            <span>Total quizzes</span>
            <strong><%= stats.totalQuizzes %></strong>
            <small>all quizzes in your workspace</small>
          </div>
          <div class="hero-mini-card">
            <span>Published</span>
            <strong><%= stats.publishedQuizzes %></strong>
            <small>ready for student attempts</small>
          </div>
          <div class="hero-mini-card">
            <span>Total attempts</span>
            <strong><%= stats.totalAttempts %></strong>
            <small>student submissions received</small>
          </div>
          <div class="hero-mini-card">
            <span>Pending reviews</span>
            <strong><%= stats.pendingReviews %></strong>
            <small>manual checks still waiting</small>
          </div>
        </div>
      </div>
    </section>

    <section class="dashboard-overview">
      <article class="chart-card">
        <div class="panel-header">
          <div class="panel-header__copy">
            <span class="eyebrow">Quiz Overview</span>
            <h2>Published vs draft quizzes</h2>
            <p>A quick view of how your quiz library is currently split.</p>
          </div>
        </div>

        <div class="chart-card__body">
          <div class="donut-chart" style="--chart-fill: <%= teacherChartFill %>;">
            <div class="donut-chart__center">
              <strong class="donut-chart__value"><%= totalQuizMix %></strong>
              <span class="donut-chart__label">Total quizzes</span>
            </div>
          </div>

          <div class="chart-legend">
            <% teacherQuizSegments.forEach((segment) => { %>
              <div class="legend-item">
                <span class="legend-dot" style="background: <%= segment.color %>;"></span>
                <div class="legend-copy">
                  <strong><%= segment.label %></strong>
                  <span><%= segment.detail %></span>
                </div>
                <span class="legend-value"><%= segment.count %></span>
              </div>
            <% }) %>
          </div>
        </div>
      </article>

      <div class="dashboard-side-stack">
        <div class="compact-stat-grid">
          <article class="compact-stat">
            <span>Drafts</span>
            <strong><%= stats.draftQuizzes %></strong>
            <small>Quizzes still being refined</small>
          </article>
          <article class="compact-stat">
            <span>Total Attempts</span>
            <strong><%= stats.totalAttempts %></strong>
            <small>All student activity</small>
          </article>
          <article class="compact-stat">
            <span>Pending Reviews</span>
            <strong><%= stats.pendingReviews %></strong>
            <small>Waiting for manual grading</small>
          </article>
        </div>

        <div class="support-card">
          <span class="eyebrow">Teacher Focus</span>
          <h3>Keep the next action clear</h3>
          <p>
            <% if (stats.pendingReviews > 0) { %>
              You have <strong><%= stats.pendingReviews %></strong> submission<%= stats.pendingReviews === 1 ? '' : 's' %> waiting for review.
            <% } else if (stats.draftQuizzes > 0) { %>
              You still have <strong><%= stats.draftQuizzes %></strong> draft <%= stats.draftQuizzes === 1 ? 'quiz' : 'quizzes' %> to polish or publish.
            <% } else { %>
              Your queue is under control, so this is a good time to create or improve a quiz.
            <% } %>
          </p>
          <div class="support-list">
            <a href="/teacher/quizzes/new"><i class="fas fa-plus"></i><span>Create a quiz</span></a>
            <a href="/teacher/quizzes"><i class="fas fa-book"></i><span>Manage quiz library</span></a>
            <a href="/teacher/reviews"><i class="fas fa-list-check"></i><span>Open review queue</span></a>
          </div>
        </div>
      </div>
    </section>

    <section class="table-card table-shell">
      <div class="panel-header">
        <div class="panel-header__copy">
          <span class="eyebrow">Main Actions</span>
          <h2>Open the flow you need</h2>
          <p>Go straight to quiz creation, management, or student review work.</p>
        </div>
      </div>

      <div class="action-grid">
        <a href="/teacher/quizzes/new" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill approved">Create</span>
              <h3 class="mt-3">Build a new quiz</h3>
              <p>Start a fresh assessment and add questions in one pass.</p>
            </div>
            <span class="metric-card__icon"><i class="fas fa-plus"></i></span>
          </div>
          <span class="action-card__footer">Open builder <i class="fas fa-arrow-right"></i></span>
        </a>

        <a href="/teacher/quizzes" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill approved">Manage</span>
              <h3 class="mt-3">Organize quiz library</h3>
              <p>Edit details, publish drafts, and keep assessments tidy.</p>
            </div>
            <span class="action-card__count"><%= stats.totalQuizzes %></span>
          </div>
          <span class="action-card__footer">View quiz list <i class="fas fa-arrow-right"></i></span>
        </a>

        <a href="/teacher/reviews" class="action-card">
          <div class="action-card__top">
            <div>
              <span class="status-pill pending">Review</span>
              <h3 class="mt-3">Handle pending feedback</h3>
              <p>Manual reviews waiting for a score or comment.</p>
            </div>
            <span class="action-card__count"><%= stats.pendingReviews %></span>
          </div>
          <span class="action-card__footer">Open review queue <i class="fas fa-arrow-right"></i></span>
        </a>
      </div>
    </section>

    <section class="table-card table-shell">
      <div class="panel-header">
        <div class="panel-header__copy">
          <span class="eyebrow">Recent Quizzes</span>
          <h2>Latest activity in your library</h2>
          <p>Your five most recently created quizzes and their current status.</p>
        </div>
        <a href="/teacher/quizzes" class="btn btn-outline-primary btn-sm">View all quizzes</a>
      </div>

      <% if (quizzes && quizzes.length > 0) { %>
        <div class="activity-list">
          <% quizzes.slice(0, 5).forEach((quiz) => { %>
            <article class="activity-item">
              <div class="activity-item__main">
                <span class="activity-item__icon"><i class="fas fa-file-lines"></i></span>
                <div>
                  <p class="activity-item__title"><%= quiz.title %></p>
                  <p class="activity-item__meta">
                    <%= quiz.questions ? quiz.questions.length : 0 %> question<%= quiz.questions && quiz.questions.length === 1 ? '' : 's' %> ·
                    <%= new Date(quiz.createdAt).toLocaleDateString() %>
                  </p>
                </div>
              </div>
              <div class="activity-score">
                <strong><%= quiz.enrolledCount || 0 %></strong>
                <span><%= quiz.status === 'published' ? 'Published' : 'Draft' %></span>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h3>No quizzes yet</h3>
          <p>Create your first quiz to start collecting student attempts and analytics.</p>
          <a href="/teacher/quizzes/new" class="btn btn-primary mt-3">Create quiz</a>
        </div>
      <% } %>
    </section>
  </div>
</section>
