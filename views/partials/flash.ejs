<!-- Toast Notifications -->
<div class="fixed top-4 right-4 z-50 space-y-2" x-data="{ toasts: [] }" x-init="
  <% success.forEach((message, index) => { %>
    toasts.push({ id: 'success-<%= index %>', type: 'success', message: '<%= message.replace(/'/g, '\\\'') %>', show: true });
    setTimeout(() => { toasts.find(t => t.id === 'success-<%= index %>').show = false; }, 5000);
  <% }) %>
  <% error.forEach((message, index) => { %>
    toasts.push({ id: 'error-<%= index %>', type: 'error', message: '<%= message.replace(/'/g, '\\\'') %>', show: true });
    setTimeout(() => { toasts.find(t => t.id === 'error-<%= index %>').show = false; }, 5000);
  <% }) %>
">
  <template x-for="toast in toasts" :key="toast.id">
    <div
      x-show="toast.show"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 transform translate-x-full"
      x-transition:enter-end="opacity-100 transform translate-x-0"
      x-transition:leave="transition ease-in duration-300"
      x-transition:leave-start="opacity-100 transform translate-x-0"
      x-transition:leave-end="opacity-0 transform translate-x-full"
      class="max-w-sm w-full bg-white shadow-lg rounded-lg border-l-4 p-4"
      :class="{
        'border-l-green-500': toast.type === 'success',
        'border-l-red-500': toast.type === 'error'
      }"
    >
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <i
            class="text-lg"
            :class="{
              'fas fa-check-circle text-green-500': toast.type === 'success',
              'fas fa-exclamation-triangle text-red-500': toast.type === 'error'
            }"
          ></i>
        </div>
        <div class="ml-3 w-0 flex-1">
          <p class="text-sm font-medium text-gray-900" x-text="toast.message"></p>
        </div>
        <div class="ml-4 flex-shrink-0 flex">
          <button
            @click="toast.show = false"
            class="inline-flex text-gray-400 hover:text-gray-600 transition-colors"
          >
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>
    </div>
  </template>
</div>
