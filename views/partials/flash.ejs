<!-- Toast Notifications -->
<div class="fixed top-4 right-4 z-50 space-y-2" x-data="{ toasts: [] }" x-init="
  <% success.forEach((message, index) => { %>
    toasts.push({ id: 'success-<%= index %>', type: 'success', message: '<%= message.replace(/'/g, '\\\'') %>', show: true });
    setTimeout(() => { toasts.find(t => t.id === 'success-<%= index %>').show = false; }, 5000);
  <% }) %>
  <% error.forEach((message, index) => { %>
    toasts.push({ id: 'error-<%= index %>', type: 'error', message: '<%= message.replace(/'/g, '\\\'') %>', show: true });
    setTimeout(() => { toasts.find(t => t.id === 'error-<%= index %>').show = false; }, 5000);
  <% }) %>
">
  <template x-for="toast in toasts" :key="toast.id">
    <div
      x-show="toast.show"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 transform translate-x-full"
      x-transition:enter-end="opacity-100 transform translate-x-0"
      x-transition:leave="transition ease-in duration-300"
      x-transition:leave-start="opacity-100 transform translate-x-0"
      x-transition:leave-end="opacity-0 transform translate-x-full"
      class="max-w-sm w-full bg-white/95 backdrop-blur-md border border-slate-200 shadow-2xl rounded-3xl p-5 overflow-hidden"
      :class="{
        'border-l-8 border-l-emerald-400': toast.type === 'success',
        'border-l-8 border-l-rose-400': toast.type === 'error'
      }"
    >
      <div class="flex items-start gap-3">
        <div class="flex h-11 w-11 items-center justify-center rounded-2xl"
          :class="{
            'bg-emerald-100 text-emerald-600': toast.type === 'success',
            'bg-rose-100 text-rose-600': toast.type === 'error'
          }"
        >
          <i
            class="text-lg"
            :class="{
              'fas fa-check': toast.type === 'success',
              'fas fa-exclamation-triangle': toast.type === 'error'
            }"
          ></i>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-slate-900 mb-1" x-text="toast.type === 'success' ? 'Success' : 'Attention'"></p>
          <p class="text-sm leading-6 text-slate-700" x-text="toast.message"></p>
        </div>
        <div class="flex-shrink-0">
          <button
            @click="toast.show = false"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full text-slate-500 hover:bg-slate-100 hover:text-slate-700 transition"
            aria-label="Dismiss notification"
          >
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>
    </div>
  </template>
</div>
