<div class="quiz-card reveal">
  <% if (typeof badge !== 'undefined' && badge) { %><span class="badge text-bg-light"><%= badge %></span><% } %>
  <h3 class="h5 mt-2"><%= title %></h3>
  <p class="text-muted"><%= description || 'No description provided.' %></p>
  <%- typeof footer !== 'undefined' ? footer : '' %>
</div>
